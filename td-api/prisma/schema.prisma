generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Player {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  rank      String
  club      String?
  agaId     String   @unique
  rating    Int?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Tournament {
  id            String               @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String?
  date          DateTime
  location      String?
  status        String               @default("setup")
  settings      TournamentSettings
  divisions     Division[]
  registrations PlayerRegistration[]
  rounds        Round[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([date])
  @@index([status])
}

type Division {
  id          String
  name        String
  description String?
}

type TournamentSettings {
  numRounds            Int
  pairingAlgorithm     String   @default("mcmahon")
  handicapType         String   @default("rank_difference")
  handicapModifier     String   @default("none")
  mcmahonBar           String?
  crossDivisionPairing Boolean  @default(true)
  tiebreakerOrder      String[] @default(["wins", "sos", "sds", "hth"])
}

type PlayerRegistration {
  playerId            String   @db.ObjectId
  divisionId          String?
  roundsParticipating Int[]
  registeredAt        DateTime @default(now())
  withdrawn           Boolean  @default(false)
}

type Round {
  number      Int
  status      String    @default("pending")
  pairings    Pairing[]
  byes        Bye[]
  pairedAt    DateTime?
  completedAt DateTime?
}

type Pairing {
  blackPlayerId  String @db.ObjectId
  whitePlayerId  String @db.ObjectId
  boardNumber    Int
  handicapStones Int    @default(0)
  komi           Float  @default(7.5)
  result         String @default("NR")
}

type Bye {
  playerId String @db.ObjectId
  points   Float  @default(1.0)
}
